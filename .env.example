# ============================================================
# BridgeStay — Environment Variables Template
# ============================================================
# Copy this file to .env for local development or your deploy target.
# Never commit real secrets.

# ----------------------------------------------------------
# Core server config (required in production)
# ----------------------------------------------------------
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/bridgestay
JWT_SECRET=change-me-to-a-long-random-secret
OAUTH_SERVER_URL=https://oauth.example.com
OWNER_OPEN_ID=your-owner-open-id
VITE_APP_ID=your-app-id
VITE_OAUTH_PORTAL_URL=https://oauth.example.com

# ----------------------------------------------------------
# Frontend integrations
# ----------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GOOGLE_MAPS_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ----------------------------------------------------------
# Optional AI / Forge integrations
# ----------------------------------------------------------
GEMINI_API_KEY=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ----------------------------------------------------------
# Optional payments
# ----------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------
# Local-only helper
# ----------------------------------------------------------
# Never enable in production. This bypasses auth locally.
DEV_DEMO_MODE=false
