# ============================================================
# BridgeStay — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================


# ----------------------------------------------------------
# OpenAI
# ----------------------------------------------------------
# Your OpenAI API key. Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------
# Supabase
# ----------------------------------------------------------
# Your Supabase project URL. Found in: Project Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe for client use)
# Found in: Project Settings → API → Project API Keys → anon / public
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key (server-side only — keep this secret)
# Found in: Project Settings → API → Project API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------
# App Core
# ----------------------------------------------------------
# Port for the Express dev server
PORT=3000

# Node environment
NODE_ENV=development

# MySQL database connection string (used by Drizzle ORM)
DATABASE_URL=mysql://user:password@localhost:3306/bridgestay

# JWT secret for signing session cookies (use a long random string)
JWT_SECRET=change-me-to-a-long-random-secret


# ----------------------------------------------------------
# Auth (Manus OAuth — current auth provider)
# ----------------------------------------------------------
# Manus OAuth server URL
OAUTH_SERVER_URL=https://oauth.example.com

# Open ID of the platform owner/admin account
OWNER_OPEN_ID=your-owner-open-id

# Manus App ID (also used as VITE_APP_ID on the client)
VITE_APP_ID=your-app-id

# Built-in Forge API (Manus internal — used for AI generation features)
BUILT_IN_FORGE_API_URL=https://forge.example.com
BUILT_IN_FORGE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------
# Stripe (payments)
# ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------
# AWS S3 (image uploads)
# ----------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
